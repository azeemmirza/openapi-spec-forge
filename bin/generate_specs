#!/usr/bin/env python3


import json
import sys
from pathlib import Path

OUT = Path(__file__).parent.parent / 'examples'


# shared builders

page_params = [
    {'name': 'page',     'in': 'query', 'schema': {'type': 'integer', 'default': 1}},
    {'name': 'pageSize', 'in': 'query', 'schema': {'type': 'integer', 'default': 20}},
]

error_content = {'application/json': {'schema': {'$ref': '#/components/schemas/Error'}}}

# i might need to add more specific error responses for certain endpoints, but this is a good starting point for all generic errors
error_responses = {
    400: {'description': 'Bad Request',           'content': error_content},
    401: {'description': 'Unauthorized',          'content': error_content},
    403: {'description': 'Forbidden',             'content': error_content},
    404: {'description': 'Not Found',             'content': error_content},
    422: {'description': 'Unprocessable Entity',  'content': error_content},
    500: {'description': 'Internal Server Error', 'content': error_content},
}

error_schema = {
    'type': 'object',
    'required': ['code', 'message'],
    'properties': {
        'code':      {'type': 'string', 'example': 'INVALID_REQUEST', 'description': 'Machine-readable error code'},
        'message':   {'type': 'string', 'example': 'The request was invalid.', 'description': 'Human-readable error description'},
        'details': {
            'type': 'array',
            'description': 'Field-level validation errors',
            'items': {
                'type': 'object',
                'properties': {
                    'field':   {'type': 'string'},
                    'message': {'type': 'string'},
                    'code':    {'type': 'string'},
                },
            },
        },
        'requestId': {'type': 'string', 'format': 'uuid', 'readOnly': True},
        'timestamp': {'type': 'string', 'format': 'date-time', 'readOnly': True},
    },
}


def to_pascal(s):
    import re
    s = re.sub(r'-([a-z])', lambda m: m.group(1).upper(), s)
    return s[0].upper() + s[1:] if s else s

def to_camel(s):
    import re
    return re.sub(r'-([a-z])', lambda m: m.group(1).upper(), s)

def id_param(name):
    return {'name': f'{name}Id', 'in': 'path', 'required': True, 'schema': {'type': 'string', 'format': 'uuid'}}

def list_resp(ref):
    return {
        'description': 'Success',
        'content': {'application/json': {'schema': {'type': 'object', 'properties': {
            'data': {'type': 'array', 'items': {'$ref': f'#/components/schemas/{ref}'}},
            'total': {'type': 'integer'}, 'page': {'type': 'integer'}, 'pageSize': {'type': 'integer'},
        }}}},
    }

def item_resp(ref):
    return {'description': 'Success', 'content': {'application/json': {'schema': {'$ref': f'#/components/schemas/{ref}'}}}}

def body_param(ref):
    return {'required': True, 'content': {'application/json': {'schema': {'$ref': f'#/components/schemas/{ref}'}}}}

def make_schema(name, extra=None):
    props = {
        'id':        {'type': 'string', 'format': 'uuid', 'readOnly': True},
        'createdAt': {'type': 'string', 'format': 'date-time', 'readOnly': True},
        'updatedAt': {'type': 'string', 'format': 'date-time', 'readOnly': True},
        'status':    {'type': 'string', 'enum': ['active', 'inactive', 'pending', 'closed', 'suspended']},
    }
    if extra:
        props.update(extra)
    return {'type': 'object', 'properties': props}

def list_op(tag, summary, schema, extra=None):
    params = page_params + (extra or [])
    return {'tags': [tag], 'summary': summary, 'parameters': params, 'responses': {200: list_resp(schema), **error_responses}}

def create_op(tag, summary, body, res):
    return {'tags': [tag], 'summary': summary, 'requestBody': body_param(body), 'responses': {201: item_resp(res), **error_responses}}

def get_op(tag, summary, schema, params=None):
    return {'tags': [tag], 'summary': summary, 'parameters': params or [], 'responses': {200: item_resp(schema), **error_responses}}

def put_op(tag, summary, body, res, params=None):
    return {'tags': [tag], 'summary': summary, 'parameters': params or [], 'requestBody': body_param(body), 'responses': {200: item_resp(res), **error_responses}}

def patch_op(tag, summary, body, res, params=None):
    return {'tags': [tag], 'summary': summary, 'parameters': params or [], 'requestBody': body_param(body), 'responses': {200: item_resp(res), **error_responses}}

def del_op(tag, summary, params=None):
    return {'tags': [tag], 'summary': summary, 'parameters': params or [], 'responses': {204: {'description': 'Deleted'}, **error_responses}}

def action_op(tag, summary, body, res, params=None):
    op = {'tags': [tag], 'summary': summary, 'parameters': params or [], 'responses': {200: item_resp(res), **error_responses}}
    if body:
        op['requestBody'] = body_param(body)
    return op


def build_spec(title, version, description, contact, servers, tag_defs, groups):
    paths = {}
    schemas = {'Error': error_schema}
    count = 0

    for grp in groups:
        g = grp['group']
        tag = grp['tag']
        subs = grp.get('subs', [])
        actions = grp.get('actions', [])
        extra_filters = grp.get('extraFilters', [])

        G = to_pascal(g)

        schemas[G] = make_schema(G, {'name': {'type': 'string'}})
        schemas[f'{G}Input'] = {'type': 'object', 'properties': {'name': {'type': 'string'}, 'status': {'type': 'string'}}}

        paths[f'/{g}'] = {
            'get':  list_op(tag, f'List {g}', G, [{'name': f, 'in': 'query', 'schema': {'type': 'string'}} for f in extra_filters]),
            'post': create_op(tag, f'Create {g[:-1] or g}', f'{G}Input', G),
        }
        count += 2

        paths[f'/{g}/{{{g}Id}}'] = {
            'get':    get_op(tag, f'Get {g[:-1] or g}', G, [id_param(g)]),
            'put':    put_op(tag, f'Update {g[:-1] or g}', f'{G}Input', G, [id_param(g)]),
            'patch':  patch_op(tag, f'Patch {g[:-1] or g}', f'{G}Input', G, [id_param(g)]),
            'delete': del_op(tag, f'Delete {g[:-1] or g}', [id_param(g)]),
        }
        count += 4

        get_actions = {'summary', 'statistics', 'count', 'balance', 'status', 'validate'}
        for action in actions:
            S = f'{G}{to_pascal(action)}'
            schemas[S] = make_schema(S)
            paths[f'/{g}/{action}'] = (
                {'get': get_op(tag, f'{action} {g}', S, list(page_params))}
                if action in get_actions
                else {'post': action_op(tag, f'{action} {g}', f'{G}Input', S)}
            )
            count += 1

        for sub in subs:
            Sub = to_pascal(sub)
            Key = f'{G}{Sub}'
            sub_id = to_camel(sub)

            schemas[Key] = make_schema(Key, {f'{g}Id': {'type': 'string', 'format': 'uuid'}})
            schemas[f'{Key}Input'] = {'type': 'object', 'properties': {'status': {'type': 'string'}, 'notes': {'type': 'string'}}}

            paths[f'/{g}/{{{g}Id}}/{sub}'] = {
                'get':  list_op(tag, f'List {g} {sub}', Key, [id_param(g)] + list(page_params)),
                'post': create_op(tag, f'Create {g} {sub.rstrip("s") or sub}', f'{Key}Input', Key),
            }
            count += 2

            paths[f'/{g}/{{{g}Id}}/{sub}/{{{sub_id}Id}}'] = {
                'get':    get_op(tag, f'Get {g} {sub.rstrip("s") or sub}', Key, [id_param(g), id_param(sub_id)]),
                'put':    put_op(tag, f'Update {g} {sub.rstrip("s") or sub}', f'{Key}Input', Key, [id_param(g), id_param(sub_id)]),
                'patch':  patch_op(tag, f'Patch {g} {sub.rstrip("s") or sub}', f'{Key}Input', Key, [id_param(g), id_param(sub_id)]),
                'delete': del_op(tag, f'Delete {g} {sub.rstrip("s") or sub}', [id_param(g), id_param(sub_id)]),
            }
            count += 4

            for a in ['summary', 'export', 'count', 'validate']:
                SA = f'{Key}{to_pascal(a)}'
                schemas[SA] = make_schema(SA)
                paths[f'/{g}/{{{g}Id}}/{sub}/{a}'] = (
                    {'get': get_op(tag, f'{a} {g} {sub}', SA, [id_param(g)] + list(page_params))}
                    if a in ('summary', 'count')
                    else {'post': action_op(tag, f'{a} {g} {sub}', f'{Key}Input', SA, [id_param(g)])}
                )
                count += 1

    spec = {
        'openapi': '3.0.2',
        'info': {'title': title, 'version': version, 'description': description, 'contact': contact, 'license': {'name': 'MIT'}},
        'servers': servers,
        'tags': tag_defs,
        'paths': paths,
        'components': {
            'schemas': schemas,
            'securitySchemes': {
                'BearerAuth': {'type': 'http', 'scheme': 'bearer', 'bearerFormat': 'JWT'},
                'ApiKeyAuth':  {'type': 'apiKey', 'in': 'header', 'name': 'X-API-Key'},
                'OAuth2':      {'type': 'oauth2', 'flows': {'clientCredentials': {'tokenUrl': '/oauth/token', 'scopes': {}}}},
            },
        },
        'security': [{'BearerAuth': []}],
    }

    return spec, count, len(paths), len(schemas)


def tag_defs(groups):
    return [{'name': g['tag'], 'description': f"{g['tag']} management"} for g in groups]


