# add default actions to healthcare groups
_hc_actions = ['search', 'export', 'import', 'validate', 'summary', 'statistics', 'bulk-create', 'bulk-update', 'bulk-delete', 'count']
for _g in healthcare_groups:
    _g.setdefault('actions', _hc_actions)
    _g.setdefault('extraFilters', ['status', 'search'])


# ── generate & write ───────────────────────────────────────────────────────

def main():
    OUT.mkdir(exist_ok=True)

    banking_spec, b_count, b_paths, b_schemas = build_spec(
        title='Banking Platform API',
        version='2.0.0',
        description='Comprehensive banking platform API covering accounts, payments, loans, cards, KYC, compliance, and more.',
        contact={'name': 'API Support', 'email': 'api@bank.example.com'},
        servers=[
            {'url': 'https://api.bank.example.com/v2', 'description': 'Production'},
            {'url': 'https://sandbox.bank.example.com/v2', 'description': 'Sandbox'},
        ],
        tag_defs=tag_defs(banking_groups),
        groups=banking_groups,
    )

    ecommerce_spec, e_count, e_paths, e_schemas = build_spec(
        title='E-Commerce Platform API',
        version='1.0.0',
        description='Full-featured e-commerce API covering products, orders, inventory, customers, promotions, fulfilment, and analytics.',
        contact={'name': 'Developer Support', 'email': 'dev@shop.example.com'},
        servers=[
            {'url': 'https://api.shop.example.com/v1', 'description': 'Production'},
            {'url': 'https://staging-api.shop.example.com/v1', 'description': 'Staging'},
        ],
        tag_defs=tag_defs(ecommerce_groups),
        groups=ecommerce_groups,
    )

    healthcare_spec, h_count, h_paths, h_schemas = build_spec(
        title='Healthcare Insurance Platform API',
        version='1.0.0',
        description='Comprehensive healthcare insurance platform API covering claims, adjudication, members, providers, eligibility, and more.',
        contact={'name': 'API Support', 'email': 'api-support@example.com'},
        servers=[
            {'url': 'https://api.example.com/v1', 'description': 'Production'},
            {'url': 'https://staging-api.example.com/v1', 'description': 'Staging'},
        ],
        tag_defs=tag_defs(healthcare_groups),
        groups=healthcare_groups,
    )

    (OUT / 'example-one.json').write_text(json.dumps(banking_spec, indent=2), encoding='utf-8')
    (OUT / 'example-two.json').write_text(json.dumps(ecommerce_spec, indent=2), encoding='utf-8')
    (OUT / 'large.json').write_text(json.dumps(healthcare_spec, indent=2), encoding='utf-8')

    b_mb = len(json.dumps(banking_spec)) / 1048576
    e_mb = len(json.dumps(ecommerce_spec)) / 1048576
    h_mb = len(json.dumps(healthcare_spec)) / 1048576

    print(f'example-one.json (Banking)')
    print(f'  Paths: {b_paths}  Endpoints: {b_count}  Schemas: {b_schemas}  Size: {b_mb:.1f} MB')
    print(f'\nexample-two.json (E-Commerce)')
    print(f'  Paths: {e_paths}  Endpoints: {e_count}  Schemas: {e_schemas}  Size: {e_mb:.1f} MB')
    print(f'\nlarge.json (Healthcare)')
    print(f'  Paths: {h_paths}  Endpoints: {h_count}  Schemas: {h_schemas}  Size: {h_mb:.1f} MB')


if __name__ == '__main__':
    main()
